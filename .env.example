# Ubion LiteLLM 프록시. 앱 사이드바 설정(data/user_settings.json)이 우선한다.
# 여기에 채워두면 앱 첫 실행 시 기본값으로 미리 들어간다(팀 배포 시 편리).
UBION_LITELLM_URL=http://192.168.50.119:4000
UBION_LITELLM_KEY=
# 기본 모델 (deepseek-v4-flash-think | claude-sonnet-4-6 | claude-opus-4-7 | ...)
UBION_LITELLM_MODEL=deepseek-v4-flash-think

# Streamlit 포트
STREAMLIT_SERVER_PORT=8701
