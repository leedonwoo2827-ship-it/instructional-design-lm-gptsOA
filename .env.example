# LLM 백엔드는 ChatGPT 계정 OAuth(구독)로 연결합니다.
# API 키는 필요 없습니다 — 앱 사이드바 '연결 설정 → ChatGPT 로그인'에서 브라우저로 로그인하세요.
# 로그인 토큰은 data/chatgpt_auth.json 에 저장됩니다(커밋 금지).

# 기본 모델 슬러그 (앱 사이드바 설정이 우선). 예: gpt-5.1 | gpt-5.1-codex | gpt-5 | gpt-5-codex
CHATGPT_MODEL=gpt-5.1
# gpt-5 계열 추론 강도 (low | medium | high)
CHATGPT_EFFORT=medium

# (선택) 디자인 슬라이드 사진 고품질화 — Unsplash Access Key. 비우면 Openverse(무료 CC).
UNSPLASH_ACCESS_KEY=

# Streamlit 포트
STREAMLIT_SERVER_PORT=8701
